# Инициализация: записываем массив [3, 5, 2, 7] в память (адреса 0–3)
push_imm 3           # Помещаем 3 в стек, b становится 3
sw_to_imm_addr 0     # Сохраняем 3 по адресу 0
push_imm 5           # Помещаем 5 в стек, b становится 5
sw_to_imm_addr 1     # Сохраняем 5 по адресу 1
push_imm 2           # Помещаем 2 в стек, b становится 2
sw_to_imm_addr 2     # Сохраняем 2 по адресу 2
push_imm 7           # Помещаем 7 в стек, b становится 7
sw_to_imm_addr 3     # Сохраняем 7 по адресу 3

# Инициализация переменных
push_imm 0           # Начальный адрес массива (0), b становится 0
sw_to_imm_addr 6     # Загружаем адрес в регистр a
push_imm 4           # Количество элементов (4), b становится 4
sw_to_imm_addr 5     # Сохраняем счетчик по адресу 5
push_imm 0           # Инициализируем сумму нулем, b становится 0

# Цикл суммирования
call 14

push_a
inc
sw_to_imm_addr 6
push_imm 1           # Помещаем 1 в стек, b становится 1
lw_from_im_addr 5    # Загружаем счетчик из памяти (адрес 5)
-                    # Вычитаем 1 из счетчика
dup
sw_to_imm_addr 5     # Сохраняем обновленный счетчик по адресу 5
if 2                 # Если счетчик == 0, пропускаем 2 инструкции (выходим из цикла)
pop
jmp -12               # Переходим назад на 8 инструкций (к lw_from_a_addr)
pop
sw_to_imm_addr 4     # Сохраняем сумму по адресу 4
halt                 # Завершаем программу

lw_from_im_addr 6
load_T_a_pop
lw_from_a_addr       # Загружаем значение по адресу в регистре a (текущий элемент)
+                    # Складываем с текущей суммой
ret


